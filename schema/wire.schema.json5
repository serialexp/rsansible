// rsansible wire protocol.
//
// Generated by binschema (`just gen-wire`). Framing (length-prefix per
// Message) is wired by hand in crates/wire/src/framing.rs — binschema doesn't
// ship a framing helper and we want the controller↔agent loop to drive its
// own AsyncRead/AsyncWrite. Encoding/decoding of a single Message stays here.
//
// Each variant in the Message and Op unions starts with a `kind: uint8`
// const at offset 0. Discrimination is peek-based — the decoder reads byte 0
// without consuming it, picks a variant, then decodes from the start. We
// avoid `field`-based discriminators because the Rust generator hasn't
// implemented those (see ~/Projects/binschema/GAPS.md).
{
  meta: {
    title: "rsansible wire protocol",
    description: "Controller↔agent RPC messages.",
    version: "0.0.1",
  },
  config: {
    endianness: "little_endian",
    bit_order: "msb_first",
  },
  types: {
    // ── Op variants ───────────────────────────────────────────────────
    // Each carries a unique `kind` byte at offset 0.

    OpExec: {
      description: "Spawn a process directly (argv form). Pipes stdout/stderr back as TaskProgress chunks.",
      sequence: [
        { name: "kind", type: "uint8", const: 0 },
        {
          name: "argv",
          type: "array",
          kind: "length_prefixed",
          length_type: "uint16",
          items: { type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        },
        // CSR-style env: parallel keys[]/values[] arrays. Cheaper on the wire
        // than a map of {key, value} pairs and trivial to assemble agent-side.
        {
          name: "env_keys",
          type: "array",
          kind: "length_prefixed",
          length_type: "uint16",
          items: { type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        },
        {
          name: "env_values",
          type: "array",
          kind: "length_prefixed",
          length_type: "uint16",
          items: { type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        },
        // Empty string = "use current working directory". Avoids an optional
        // field, which the Rust generator handles less consistently than plain
        // length-prefixed strings.
        { name: "cwd", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        // Empty bytes = no stdin. Same reasoning as cwd.
        { name: "stdin", type: "bytes", kind: "length_prefixed", length_type: "uint32" },
        // 0 = no timeout.
        { name: "timeout_ms", type: "uint32" },
      ],
    },

    OpShell: {
      description: "Run `sh -c <command>`. Same plumbing as OpExec for output.",
      sequence: [
        { name: "kind", type: "uint8", const: 1 },
        { name: "command", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        { name: "timeout_ms", type: "uint32" },
      ],
    },

    OpWriteFile: {
      description: "Atomic write: tmp + fsync + rename. `changed` in TaskDone is set iff content or mode differed.",
      sequence: [
        { name: "kind", type: "uint8", const: 2 },
        { name: "path", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        // Permission bits (octal in YAML, decoded to u32 here). Only the low 12
        // bits are meaningful but uint32 keeps room for setuid/sticky etc.
        { name: "mode", type: "uint32" },
        { name: "content", type: "bytes", kind: "length_prefixed", length_type: "uint32" },
      ],
    },

    // Op dispatch. Each variant is identified by its leading `kind` byte; the
    // peek discriminator reads that byte without consuming it.
    Op: {
      description: "Discriminated union of all operations the agent can execute.",
      type: "discriminated_union",
      discriminator: { peek: "uint8" },
      variants: [
        { type: "OpExec", when: "value === 0" },
        { type: "OpShell", when: "value === 1" },
        { type: "OpWriteFile", when: "value === 2" },
      ],
    },

    // ── Message variants ──────────────────────────────────────────────

    Hello: {
      description: "Sent agent → controller on startup. Carries identifying facts.",
      sequence: [
        { name: "kind", type: "uint8", const: 0 },
        // Arch / OS as small enum-ish bytes. Strings would work but the values
        // are bounded and the controller wants to match on them anyway.
        // 0=unknown, 1=x86_64, 2=aarch64, 3=arm, 4=riscv64, …
        { name: "arch", type: "uint8" },
        // 0=unknown, 1=linux, 2=darwin, 3=freebsd, …
        { name: "os", type: "uint8" },
        { name: "kernel", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        { name: "hostname", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        { name: "uid", type: "uint32" },
        { name: "gid", type: "uint32" },
        { name: "agent_version", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
      ],
    },

    TaskDispatch: {
      description: "Sent controller → agent. Asks the agent to execute one Op.",
      sequence: [
        { name: "kind", type: "uint8", const: 1 },
        // Monotonic per-host sequence id chosen by the controller. The agent
        // echoes it back in TaskProgress/TaskDone/TaskError so the controller
        // can correlate streams.
        { name: "seq", type: "uint32" },
        { name: "op", type: "Op" },
      ],
    },

    TaskProgress: {
      description: "Sent agent → controller during execution. One chunk of stdout or stderr.",
      sequence: [
        { name: "kind", type: "uint8", const: 2 },
        { name: "seq", type: "uint32" },
        // 0 = stdout, 1 = stderr. Modeled as a full byte (not a bit) so the
        // Rust generator's straightforward path handles it.
        { name: "stream", type: "uint8" },
        { name: "chunk", type: "bytes", kind: "length_prefixed", length_type: "uint32" },
      ],
    },

    TaskDone: {
      description: "Sent agent → controller. Terminal — no further messages for this seq.",
      sequence: [
        { name: "kind", type: "uint8", const: 3 },
        { name: "seq", type: "uint32" },
        { name: "exit_code", type: "int32" },
        // 0 = unchanged, 1 = changed. Idempotency reporting (Ansible-style).
        { name: "changed", type: "uint8" },
        { name: "took_ms", type: "uint32" },
      ],
    },

    TaskError: {
      description: "Sent agent → controller. Module-level failure before/instead of TaskDone.",
      sequence: [
        { name: "kind", type: "uint8", const: 4 },
        { name: "seq", type: "uint32" },
        // Coarse error category for programmatic handling. Free-form detail in `message`.
        // 0=internal, 1=bad_request, 2=io, 3=permission, 4=timeout, 5=not_found, 6=spawn_failed
        { name: "code", type: "uint8" },
        { name: "message", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
      ],
    },

    Bye: {
      description: "Sent controller → agent. Agent flushes and exits cleanly.",
      sequence: [
        { name: "kind", type: "uint8", const: 5 },
      ],
    },

    // Top-level union for the whole protocol.
    Message: {
      description: "Discriminated union of every wire message in either direction.",
      type: "discriminated_union",
      discriminator: { peek: "uint8" },
      variants: [
        { type: "Hello", when: "value === 0" },
        { type: "TaskDispatch", when: "value === 1" },
        { type: "TaskProgress", when: "value === 2" },
        { type: "TaskDone", when: "value === 3" },
        { type: "TaskError", when: "value === 4" },
        { type: "Bye", when: "value === 5" },
      ],
    },
  },
}
