// rsansible wire protocol.
//
// Generated by binschema (`just gen-wire`). Framing (length-prefix per
// Message) is wired by hand in crates/wire/src/framing.rs — binschema doesn't
// ship a framing helper and we want the controller↔agent loop to drive its
// own AsyncRead/AsyncWrite. Encoding/decoding of a single Message stays here.
//
// Each variant in the Message and Op unions starts with a `kind: uint8`
// const at offset 0. Discrimination is peek-based — the decoder reads byte 0
// without consuming it, picks a variant, then decodes from the start. We
// avoid `field`-based discriminators because the Rust generator hasn't
// implemented those (see ~/Projects/binschema/GAPS.md).
{
  meta: {
    title: "rsansible wire protocol",
    description: "Controller↔agent RPC messages.",
    version: "0.0.1",
  },
  config: {
    endianness: "little_endian",
    bit_order: "msb_first",
  },
  types: {
    // ── Op variants ───────────────────────────────────────────────────
    // Each carries a unique `kind` byte at offset 0.

    OpExec: {
      description: "Spawn a process directly (argv form). Pipes stdout/stderr back as TaskProgress chunks.",
      sequence: [
        { name: "kind", type: "uint8", const: 0 },
        {
          name: "argv",
          type: "array",
          kind: "length_prefixed",
          length_type: "uint16",
          items: { type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        },
        // CSR-style env: parallel keys[]/values[] arrays. Cheaper on the wire
        // than a map of {key, value} pairs and trivial to assemble agent-side.
        {
          name: "env_keys",
          type: "array",
          kind: "length_prefixed",
          length_type: "uint16",
          items: { type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        },
        {
          name: "env_values",
          type: "array",
          kind: "length_prefixed",
          length_type: "uint16",
          items: { type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        },
        // Empty string = "use current working directory". Avoids an optional
        // field, which the Rust generator handles less consistently than plain
        // length-prefixed strings.
        { name: "cwd", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        // Empty bytes = no stdin. Same reasoning as cwd.
        { name: "stdin", type: "bytes", kind: "length_prefixed", length_type: "uint32" },
        // 0 = no timeout.
        { name: "timeout_ms", type: "uint32" },
      ],
    },

    OpShell: {
      description: "Run `sh -c <command>`. Same plumbing as OpExec for output. `env_keys`/`env_values` mirror OpExec's CSR-style env so task-level `environment:` can be honored without falling back to in-band `KEY=val cmd` quoting tricks.",
      sequence: [
        { name: "kind", type: "uint8", const: 1 },
        { name: "command", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        {
          name: "env_keys",
          type: "array",
          kind: "length_prefixed",
          length_type: "uint16",
          items: { type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        },
        {
          name: "env_values",
          type: "array",
          kind: "length_prefixed",
          length_type: "uint16",
          items: { type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        },
        { name: "timeout_ms", type: "uint32" },
      ],
    },

    OpWriteFile: {
      description: "Atomic write: tmp + fsync + rename. `changed` in TaskDone is set iff content, mode, owner, or group differed. `only_if_missing=1` makes the write a no-op when `path` already exists (agent reports changed=0 without reading or writing); used for ship-blind idempotent paths like generated private keys where a stat-then-write round trip is more expensive than just shipping the bytes. Empty `owner`/`group` mean don't chown (the staged tmp keeps whatever EUID/EGID the agent has at file-create time); non-empty values resolve via /etc/passwd /etc/group and chown the staged tmp before rename. `validate` is a shell command run against the staged tmp file before the rename — empty means no validation. The command is tokenized on whitespace and the literal token `%s` is replaced by the tmp file path (matches Ansible's `validate:` semantics on `copy`/`template`/`lineinfile`/`blockinfile`). On a non-zero exit code from validate, the tmp file is unlinked and the dest is left untouched; the task fails with a BAD_REQUEST-shaped TaskError carrying the validator's stderr. The classic use case is `validate: /usr/sbin/visudo -cf %s` on a sudoers drop-in: a broken file never reaches /etc/sudoers.d.",
      sequence: [
        { name: "kind", type: "uint8", const: 2 },
        { name: "path", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        // Permission bits (octal in YAML, decoded to u32 here). Only the low 12
        // bits are meaningful but uint32 keeps room for setuid/sticky etc.
        { name: "mode", type: "uint32" },
        // 0 = always write (overwrite if present), 1 = skip if dest exists.
        // The fixed-size byte goes before the variable-length `content` tail
        // so the framing stays simple.
        { name: "only_if_missing", type: "uint8" },
        { name: "content", type: "bytes", kind: "length_prefixed", length_type: "uint32" },
        // Empty string = no validation. Non-empty: run as `sh -c` after the
        // tmp file is fsync'd and chmod'd, with `%s` substituted by the tmp
        // path. Non-zero exit code → unlink tmp, dest untouched, task fails.
        { name: "validate", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        // Owner / group POSIX names. Empty string = don't chown. Resolved
        // against /etc/passwd and /etc/group on the agent host (no NSS) and
        // applied via chown on the staged tmp before rename — same shape as
        // OpCopyTarget. Honors Ansible's `template:` / `copy:` owner/group
        // fields.
        { name: "owner", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        { name: "group", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
      ],
    },

    OpGatherFacts: {
      description: "Collect a small set of `ansible_*` facts about the host. The agent writes a UTF-8 JSON object to stdout via TaskProgress (one chunk) and then sends TaskDone with exit_code=0. Failures still produce TaskDone with non-zero exit_code instead of TaskError, so the controller can treat missing facts as non-fatal without special-casing.",
      sequence: [
        { name: "kind", type: "uint8", const: 3 },
      ],
    },

    OpStat: {
      description: "Stat a single filesystem path. The agent emits a UTF-8 JSON object on stdout describing the path (exists / type bits / mode / uid+gid / size / mtime / atime / ctime / sha256 / link target) and finishes with TaskDone(exit_code=0). Missing path is *not* an error: the JSON simply reports {\"exists\": false}. Hard failures (permission denied on the parent dir, etc.) surface as TaskError. `follow` selects stat() vs lstat(): 0 = lstat (don't follow final symlink), 1 = stat (follow). Matches Ansible's `follow` default of true.",
      sequence: [
        { name: "kind", type: "uint8", const: 4 },
        { name: "path", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        { name: "follow", type: "uint8" },
      ],
    },

    OpWaitFor: {
      description: "Wait for a TCP port to be reachable OR a filesystem path to appear/disappear. Mutually exclusive modes: `port > 0` selects TCP probing on (host, port); `port == 0` selects path-existence probing on `path` (the other field is sent as an empty string). `state` is a uint8: 0=present (wait for it to come up / file to exist), 1=absent (wait for it to disappear). The agent loops every `sleep_ms` (after an optional `delay_ms` initial wait) up to `timeout_ms` total. On success: TaskDone(exit_code=0, changed=0). On timeout: TaskError(code=TIMEOUT). Bad mode (both port>0 and path set, or neither) → TaskError(BAD_REQUEST).",
      sequence: [
        { name: "kind", type: "uint8", const: 6 },
        { name: "host", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        { name: "port", type: "uint32" },
        { name: "path", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        { name: "state", type: "uint8" },
        { name: "timeout_ms", type: "uint32" },
        { name: "delay_ms", type: "uint32" },
        { name: "sleep_ms", type: "uint32" },
      ],
    },

    OpFile: {
      description: "Ensure a filesystem path is in the requested state. Maps Ansible's `ansible.builtin.file` module. The agent applies the state and reports TaskDone with `changed=1` iff anything actually changed (creation, removal, mode bits flipped, owner/group changed, touch updated mtime). `state` is a uint8 enum: 0=directory (mkdir -p semantics; recurse chmod/chown if `recurse=1`), 1=absent (rm -rf if dir, unlink if file/symlink), 2=touch (create empty file if missing; always bumps mtime/atime — Ansible reports touch as always-changed), 3=file (ensure regular file exists; errors if path is missing or wrong type; still applies mode/owner/group). `has_mode` is 0/1: when 1, the low 12 bits of `mode` are applied via chmod; when 0, no chmod runs. Empty `owner`/`group` strings mean \"don't change\"; non-empty values are resolved via /etc/passwd and /etc/group (no NSS) and applied via chown. `recurse` (0/1) only applies to state=directory.",
      sequence: [
        { name: "kind", type: "uint8", const: 5 },
        { name: "path", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        { name: "state", type: "uint8" },
        { name: "has_mode", type: "uint8" },
        { name: "mode", type: "uint32" },
        { name: "owner", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        { name: "group", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        { name: "recurse", type: "uint8" },
      ],
    },

    OpLineInFile: {
      description: "Idempotent single-line edit in a text file. Maps Ansible's `ansible.builtin.lineinfile`. Semantics: `state=0 (present)` ensures a line matching `regexp` (or, when regexp is empty, matching `line` literally) is present in the file; when the match isn't found the line is appended unless `insertbefore`/`insertafter` redirects placement. `state=1 (absent)` removes every line matching `regexp` (or `line` literal). `create=1` creates the file (with `mode` if `has_mode=1`) when missing and state=present; create=0 + missing file is a no-op for absent and an error for present. `backrefs=1` substitutes regex backrefs from the match into `line` when replacing. Empty `insertbefore`/`insertafter` mean unused; the literal `EOF` for insertafter means append (Ansible convention). `changed=1` iff the on-disk bytes actually changed. `validate` is an optional command run against the staged tmp file before the rename — same shape as OpWriteFile's `validate`: empty = no validation, otherwise tokenized on whitespace and `%s` is substituted by the tmp path; non-zero exit aborts the swap and leaves dest untouched.",
      sequence: [
        { name: "kind", type: "uint8", const: 7 },
        { name: "path", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        { name: "regexp", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        { name: "line", type: "string", kind: "length_prefixed", length_type: "uint32", encoding: "utf8" },
        { name: "state", type: "uint8" },
        { name: "has_mode", type: "uint8" },
        { name: "mode", type: "uint32" },
        { name: "create", type: "uint8" },
        { name: "insertbefore", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        { name: "insertafter", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        { name: "backrefs", type: "uint8" },
        { name: "validate", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
      ],
    },

    OpBlockInFile: {
      description: "Idempotent multi-line block edit in a text file. Maps Ansible's `ansible.builtin.blockinfile`. A block is delimited by two marker comment lines whose text is built from `marker` with the literal token `{mark}` substituted for `marker_begin` (top marker) or `marker_end` (bottom marker). On state=present, the block body (the `block` field — possibly multi-line) is placed between fresh markers; if a previous block with the same markers exists it is replaced; otherwise placement follows `insertbefore`/`insertafter` (with the literal `EOF` for insertafter meaning append; default is append when both are empty). On state=absent the block and its markers are removed. `block` empty + state=present means \"remove the block if it exists.\" `create=1` creates the file (with `mode` if `has_mode=1`) when missing + state=present; create=0 + missing file is a no-op for absent and an error for present. `changed=1` iff bytes actually moved on disk. `validate` is an optional command run against the staged tmp file before the rename — same shape as OpWriteFile's `validate`: empty = no validation, otherwise tokenized on whitespace and `%s` is substituted by the tmp path; non-zero exit aborts the swap and leaves dest untouched.",
      sequence: [
        { name: "kind", type: "uint8", const: 8 },
        { name: "path", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        { name: "block", type: "string", kind: "length_prefixed", length_type: "uint32", encoding: "utf8" },
        { name: "marker", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        { name: "marker_begin", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        { name: "marker_end", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        { name: "state", type: "uint8" },
        { name: "has_mode", type: "uint8" },
        { name: "mode", type: "uint32" },
        { name: "create", type: "uint8" },
        { name: "insertbefore", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        { name: "insertafter", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        { name: "validate", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
      ],
    },

    OpPackage: {
      description: "Generic package-manager wrapper. Maps Ansible's `ansible.builtin.package` plus all the per-manager modules (`apt`, `dnf`, `yum`, `apk`, `pacman`, `zypper`, `pip`, …). `manager` selects the backend: 0=auto (agent picks based on what's on PATH / facts), 1=apt, 2=dnf, 3=yum, 4=apk, 5=pacman, 6=zypper, 7=pip. Unimplemented backends return BAD_REQUEST. `names` is the list of package names to manage (one wire op handles a batch). `state` is a uint8: 0=present (install if missing), 1=absent (remove if installed), 2=latest (install + upgrade to latest available). `update_cache=1` runs the manager's index refresh first; `cache_valid_time` (seconds) suppresses the update if the cache mtime is fresher than that (0 = always update when update_cache=1) — apt-only, ignored by other managers. `purge=1` switches absent's `remove` for `purge` (apt-only). `autoremove=1` runs an autoremove pass after the main op (apt/dnf). `default_release` maps to apt's `-t <release>` (apt-only). `allow_unauthenticated=1` adds apt's `--allow-unauthenticated` (apt-only). `virtualenv` (pip-only) is the venv path the agent should install into; empty means a system-level `pip install`. `virtualenv_command` (pip-only) is the command used to materialise the venv when it's missing (default: `python3 -m venv`). Apt backend runs apt-get with `DEBIAN_FRONTEND=noninteractive`. Pip backend probes via `<venv>/bin/pip show <name>` (or system pip when no venv) — `changed=1` iff any package installed/upgraded/removed; `state=latest` always reinstalls without a version pin so pip resolves the newest. Idempotency: state=present skips packages already installed; state=absent skips packages already absent; state=latest probes pre/post versions and reports changed iff anything moved.",
      sequence: [
        { name: "kind", type: "uint8", const: 10 },
        { name: "manager", type: "uint8" },
        {
          name: "names",
          type: "array",
          kind: "length_prefixed",
          length_type: "uint16",
          items: { type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        },
        { name: "state", type: "uint8" },
        { name: "update_cache", type: "uint8" },
        { name: "cache_valid_time", type: "uint32" },
        { name: "purge", type: "uint8" },
        { name: "autoremove", type: "uint8" },
        { name: "default_release", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        { name: "allow_unauthenticated", type: "uint8" },
        { name: "virtualenv", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        { name: "virtualenv_command", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
      ],
    },

    OpSystemd: {
      description: "systemctl wrapper. Maps Ansible's `ansible.builtin.systemd_service` / `service` (subset). `state` is a uint8: 0=unchanged (only manage enable/mask), 1=started, 2=stopped, 3=restarted, 4=reloaded. `has_enabled=1` means apply `enabled` (0/1); `has_masked=1` means apply `masked` (0/1). `daemon_reload=1` runs `systemctl daemon-reload` before anything else. `no_block=1` passes `--no-block` to start/stop/restart. Order of operations: daemon-reload → mask/unmask → enable/disable → state transition. Idempotency: the agent probes `is-active` and `is-enabled` first and skips no-op transitions; `restarted`/`reloaded` are always reported as changed (matches Ansible).",
      sequence: [
        { name: "kind", type: "uint8", const: 9 },
        { name: "name", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        { name: "state", type: "uint8" },
        { name: "has_enabled", type: "uint8" },
        { name: "enabled", type: "uint8" },
        { name: "has_masked", type: "uint8" },
        { name: "masked", type: "uint8" },
        { name: "daemon_reload", type: "uint8" },
        { name: "no_block", type: "uint8" },
      ],
    },

    OpUfw: {
      description: "`ufw` (Uncomplicated Firewall) wrapper. Maps Ansible's `community.general.ufw` (subset). `op` is a uint8: 0=rule (apply allow/deny/limit/reject), 1=enable, 2=disable, 3=reset, 4=default (set default policy), 5=reload, 6=logging. For op=rule, `rule` is one of allow/deny/limit/reject; `direction` is in/out/routed; `proto` is any/tcp/udp; `from_ip`/`to_ip` are empty for `any`; `from_port`/`to_port` are empty for any (range syntax like `5000:5010` allowed); `interface` is optional; `comment` is optional. For op=default, `rule` carries the policy (allow/deny/reject) and `direction` selects in/out/routed (empty = `incoming`). For op=logging, `rule` carries the level (on/off/low/medium/high/full). Idempotency: `ufw status verbose` is parsed once, then the requested rule is checked against the rule list (canonicalized) before any mutation. `delete=1` deletes a matching rule instead of adding it. `insert` (0 = append) inserts at the given position (1-based). Wire kind=11.",
      sequence: [
        { name: "kind", type: "uint8", const: 11 },
        { name: "op", type: "uint8" },
        { name: "rule", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        { name: "direction", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        { name: "proto", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        { name: "from_ip", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        { name: "from_port", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        { name: "to_ip", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        { name: "to_port", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        { name: "interface", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        { name: "comment", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        { name: "delete", type: "uint8" },
        { name: "insert", type: "uint32" },
      ],
    },

    OpIptables: {
      description: "`iptables` wrapper. Maps Ansible's `ansible.builtin.iptables` (subset). Manages a single rule on the host's iptables/ip6tables filter (or named) table. `rule_state` is uint8: 0=absent, 1=present. `action` is uint8: 0=append (-A, default), 1=insert (-I). `ip_version` is uint8: 4=iptables, 6=ip6tables. `table` defaults to `\"filter\"` when empty. All string knobs (`protocol`, `source`, `destination`, `source_port`, `destination_port`, `in_interface`, `out_interface`, `jump`, `ctstate`, `comment`) treat empty as \"unset\" (no corresponding flag emitted). Idempotency: the agent runs `iptables -C ...` with the same args first; if the rule already exists in the requested state, the op is a no-op and reports `changed=0`. Otherwise it dispatches `-A` / `-I` (state=present) or `-D` (state=absent). Wire kind=20. Envelope: {present: 0|1 (final state), table, chain, jump, comment}. The op runs `iptables` / `ip6tables` directly — sudo escalation comes from the controller's per-host agent pool (see CLAUDE.md), not from a flag here.",
      sequence: [
        { name: "kind", type: "uint8", const: 20 },
        { name: "table", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        { name: "chain", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        { name: "protocol", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        { name: "source", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        { name: "destination", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        { name: "source_port", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        { name: "destination_port", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        { name: "in_interface", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        { name: "out_interface", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        { name: "jump", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        { name: "ctstate", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        { name: "comment", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        { name: "ip_version", type: "uint8" },
        { name: "action", type: "uint8" },
        { name: "rule_state", type: "uint8" },
      ],
    },

    OpRepository: {
      description: "Add/remove a third-party package repository. Maps Ansible's `ansible.builtin.apt_repository` and (in future) its `yum_repository`/`zypper_repository` cousins under one canonical task name. `manager` selects the backend: 0=auto (agent picks based on what's on PATH / facts), 1=apt. Other backends (dnf/yum/apk/pacman/zypper) reserve the same byte values as OpPackage and return BAD_REQUEST until a per-manager backend lands. `repo` is the source-list line (deb URL or PPA shorthand for apt; future managers will use the same field with their own grammar). `state` is uint8: 0=present (write the file if missing/changed), 1=absent (delete the file if present). `filename` is the basename of the on-disk source file (apt: `/etc/apt/sources.list.d/<filename>.list`); empty string means \"derive from sanitised `repo` string\" (Ansible-compatible). `mode` is the unix file mode for the source file (0=use default 0o644). `update_cache=1` runs the manager's index refresh after a change (apt: `apt-get update`), suppressed when nothing changed. Idempotency: read the current file (if any), compare to the desired content; no-op if equal. Wire kind=21.",
      sequence: [
        { name: "kind", type: "uint8", const: 21 },
        { name: "manager", type: "uint8" },
        { name: "repo", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        { name: "state", type: "uint8" },
        { name: "filename", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        { name: "mode", type: "uint32" },
        { name: "update_cache", type: "uint8" },
      ],
    },

    OpGroup: {
      description: "Create or delete a unix group. Maps Ansible's `ansible.builtin.group` (subset). `name` is required. `state` is uint8: 0=present, 1=absent. `system=1` selects a system-range gid via `groupadd --system`. The agent probes with `getent group <name>` first; no-op if the group already exists in the requested state. We do NOT support `gid:` explicitly — let the OS pick. Wire kind=23.",
      sequence: [
        { name: "kind", type: "uint8", const: 23 },
        { name: "name", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        { name: "state", type: "uint8" },
        { name: "system", type: "uint8" },
      ],
    },

    OpUser: {
      description: "Create / update / delete a unix user. Maps Ansible's `ansible.builtin.user` (subset). `name` is required. `state` is uint8: 0=present, 1=absent. `system=1` selects a system-range uid via `useradd --system` (no-op on usermod once the user exists). `has_shell=1` means apply `shell` (path-to-shell, empty allowed); `has_home=1` means apply `home`. `create_home` is uint8: 0=no-create (`useradd -M`), 1=create (`useradd -m`, the Ansible default for state=present). `primary_group` is the primary group name (empty = OS default). `groups` is the supplementary-group list; `append=1` adds them to the existing membership (`usermod -a`), `append=0` replaces (`usermod -G`). The agent probes `getent passwd <name>` first; for `state=present` on an existing user it runs `usermod` with only the deltas, reporting changed iff anything actually moved. We do NOT support uid/gid/password/comment/expires/ssh-key-gen — they're refused at parse time so a fresh playbook fails loudly rather than silently dropping fields. Wire kind=22.",
      sequence: [
        { name: "kind", type: "uint8", const: 22 },
        { name: "name", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        { name: "state", type: "uint8" },
        { name: "system", type: "uint8" },
        { name: "has_shell", type: "uint8" },
        { name: "shell", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        { name: "has_home", type: "uint8" },
        { name: "home", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        { name: "create_home", type: "uint8" },
        { name: "primary_group", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        {
          name: "groups",
          type: "array",
          kind: "length_prefixed",
          length_type: "uint16",
          items: { type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        },
        { name: "append", type: "uint8" },
      ],
    },

    OpAuthorizedKey: {
      description: "Idempotent line management for `~<user>/.ssh/authorized_keys`. Maps Ansible's `ansible.posix.authorized_key` (subset). `user` is required and must already exist on the system (we don't auto-create — pair with `user:` for that). `key` is the full pubkey line (e.g. `ssh-ed25519 AAAA... comment`); the agent matches keys by the (type, key-body) pair so an updated comment doesn't double-add. `state` is uint8: 0=present, 1=absent. `exclusive=1` rotates the file to be exactly the set of {key} you specified for this user (Ansible's `exclusive: yes`); for `exclusive=0` we add or remove only the specified entry. The agent atomically writes (tmp+rename) the file with mode 0600, ensures `~/.ssh` exists with mode 0700 owned by the user, and chowns the final file to the user. Wire kind=24.",
      sequence: [
        { name: "kind", type: "uint8", const: 24 },
        { name: "user", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        { name: "key", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        { name: "state", type: "uint8" },
        { name: "exclusive", type: "uint8" },
      ],
    },

    OpGetent: {
      description: "Look up a single NSS database entry. Maps Ansible's `ansible.builtin.getent` (subset). `database` is the NSS database name (`passwd`, `group`, `hosts`, `services`, `shadow`, …) and is required. `key` is the lookup key (user name, group name, hostname, port name, …) and is required — we do NOT support the all-entries form (omitted-key returns every record), which Ansible permits but our scope hasn't needed. `fail_key=1` (the Ansible default) means TaskError on lookup miss; `fail_key=0` records `<key>: null` in the envelope and reports `changed=0`. `split` is the field separator; empty string defers to the database default (`:` for passwd/group/shadow, whitespace for hosts/services). Envelope on success: `{ \"database\": <name>, \"<key>\": [field1, field2, …] }` — the second key is dynamic, matching Ansible's `getent_<database>[<key>]` shape after the orchestrator lifts it to the register. Read-only, never reports `changed=1`. Wire kind=25.",
      sequence: [
        { name: "kind", type: "uint8", const: 25 },
        { name: "database", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        { name: "key", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        { name: "fail_key", type: "uint8" },
        { name: "split", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
      ],
    },

    OpHostname: {
      description: "Set the system hostname. Maps Ansible's `ansible.builtin.hostname` (subset). `name` is required. Idempotency: read the current hostname via `hostname` (or `/etc/hostname`); no-op if already equal. Otherwise: when `hostnamectl` is on PATH (systemd-init systems) call `hostnamectl set-hostname <name>` — that handles `/etc/hostname` and the kernel `sethostname()` in one shot. On non-systemd hosts fall back to rewriting `/etc/hostname` (mode 0644) and calling the `hostname` binary to update the running kernel value. `use:` is NOT supported on the wire today (we always auto-detect via hostnamectl-vs-fallback); pass-through of Ansible's `use:` is parse-time rejected. Wire kind=26.",
      sequence: [
        { name: "kind", type: "uint8", const: 26 },
        { name: "name", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
      ],
    },

    OpTimezone: {
      description: "Set the system timezone. Maps `community.general.timezone` (subset). `name` is required — must be a valid zoneinfo identifier (e.g. `Europe/Amsterdam`, `UTC`). Idempotency: read the current timezone via `timedatectl show --property=Timezone --value` (or the symlink target of `/etc/localtime` as fallback); no-op if already equal. Otherwise: when `timedatectl` is on PATH (systemd-init systems) call `timedatectl set-timezone <name>` — that updates the kernel time-of-day handling, rewrites `/etc/localtime`, and writes `/etc/timezone` in one shot. On non-systemd hosts fall back to symlinking `/etc/localtime` -> `/usr/share/zoneinfo/<name>` and writing `<name>` to `/etc/timezone`. Wire kind=27.",
      sequence: [
        { name: "kind", type: "uint8", const: 27 },
        { name: "name", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
      ],
    },

    OpUri: {
      description: "HTTP client. Maps Ansible's `ansible.builtin.uri` (subset). `method` is a uint8: 0=GET, 1=POST, 2=PUT, 3=PATCH, 4=DELETE, 5=HEAD. `header_keys` / `header_values` are parallel arrays carrying the request headers (case preserved on the wire; reqwest canonicalises at send time). `body_format` is a uint8: 0=raw (body shipped verbatim, no Content-Type touched), 1=json (body shipped as-is — controller pre-serialises any YAML map at parse time; Content-Type set to application/json when not already in headers), 2=form (body shipped verbatim; Content-Type set to application/x-www-form-urlencoded when not already in headers — caller does the k=v&k=v encoding). `status_codes` is the list of accepted HTTP statuses; the agent emits TaskDone with exit_code=0 when the response status is in this list, exit_code=1 otherwise. The envelope is shipped on stdout in both cases for diagnostics. `follow_redirects` is a uint8: 0=none, 1=safe (follow up to 10 hops iff the original method was GET/HEAD), 2=all (follow up to 10 hops regardless of method). `validate_certs=0` disables TLS cert/hostname verification. `return_content=1` includes the response body as a UTF-8 string in the envelope's `content` field. Envelope shape: {status: uint16, url: string, headers: map<string,string> (response headers, keys lowercased), content?: string (only if return_content), content_length: uint, content_type: string, json?: <parsed body if Content-Type indicates JSON>, elapsed_ms: uint, redirected: bool}. `changed` is 1 for any successful non-GET/HEAD request (Ansible's contract: mutating verbs report changed even if the server didn't actually change), 0 for GET/HEAD or for any failed status. Pre-status errors (connect refused, DNS, TLS handshake, timeout) surface as TaskError BAD_HOST/BAD_REQUEST without an envelope. Wire kind=12.",
      sequence: [
        { name: "kind", type: "uint8", const: 12 },
        { name: "method", type: "uint8" },
        { name: "url", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        {
          name: "header_keys",
          type: "array",
          kind: "length_prefixed",
          length_type: "uint16",
          items: { type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        },
        {
          name: "header_values",
          type: "array",
          kind: "length_prefixed",
          length_type: "uint16",
          items: { type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        },
        { name: "body", type: "bytes", kind: "length_prefixed", length_type: "uint32" },
        { name: "body_format", type: "uint8" },
        {
          name: "status_codes",
          type: "array",
          kind: "length_prefixed",
          length_type: "uint16",
          items: { type: "uint16" },
        },
        { name: "timeout_ms", type: "uint32" },
        { name: "return_content", type: "uint8" },
        { name: "validate_certs", type: "uint8" },
        { name: "follow_redirects", type: "uint8" },
        // mTLS PEM material. Empty bytes = absent. `client_cert_pem` +
        // `client_key_pem` together build a reqwest Identity (concatenated PEM
        // bundle). `ca_bundle_pem` is added as a custom root for verification.
        // Controller reads these from local files (Ansible's `client_cert` /
        // `client_key` / `ca_path`) at playbook load time and embeds the bytes
        // here, so the agent never touches the controller's filesystem.
        { name: "client_cert_pem", type: "bytes", kind: "length_prefixed", length_type: "uint32" },
        { name: "client_key_pem", type: "bytes", kind: "length_prefixed", length_type: "uint32" },
        { name: "ca_bundle_pem", type: "bytes", kind: "length_prefixed", length_type: "uint32" },
      ],
    },

    OpPostgresqlQuery: {
      description: "PostgreSQL query execution. Maps Ansible's `community.postgresql.postgresql_query` (subset). Connection: `login_unix_socket` non-empty selects UNIX-socket peer auth (current uid; Patroni clusters listen on /var/run/postgresql); empty falls back to TCP at `login_host:login_port` (host empty=localhost, port 0=5432). `login_user`/`login_password` empty means trust/peer auth (no credentials sent). `db` empty defaults to `postgres`. `autocommit=0` (default) wraps the query in BEGIN/COMMIT; `autocommit=1` runs it outside any transaction (required for VACUUM, CREATE INDEX CONCURRENTLY, etc.). `positional_args` carries query parameters as UTF-8 text — postgres-side casts handle typing (e.g. `WHERE id = $1::int`). Envelope shape on stdout: {query_result: [<row>...], rowcount: uint, statusmessage: string}. Each row is a JSON object keyed by column name; values are JSON-typed per pg oid (int → number, bool → bool, jsonb → nested, bytea → base64 string, everything else → string). `changed` is 1 unless the controller pre-classified the SQL as read-only (SELECT/SHOW/EXPLAIN/VALUES/WITH/TABLE) — the controller flips that classification into `changed=0` at register-lift time. Wire kind=13.",
      sequence: [
        { name: "kind", type: "uint8", const: 13 },
        { name: "query", type: "string", kind: "length_prefixed", length_type: "uint32", encoding: "utf8" },
        { name: "db", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        { name: "login_user", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        { name: "login_password", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        { name: "login_unix_socket", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        { name: "login_host", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        { name: "login_port", type: "uint16" },
        { name: "autocommit", type: "uint8" },
        {
          name: "positional_args",
          type: "array",
          kind: "length_prefixed",
          length_type: "uint16",
          items: { type: "string", kind: "length_prefixed", length_type: "uint32", encoding: "utf8" },
        },
        { name: "read_only", type: "uint8" },
      ],
    },

    OpPostgresqlExt: {
      description: "PostgreSQL extension management. Maps Ansible's `community.postgresql.postgresql_ext`. `state` is a uint8: 0=present, 1=absent. `cascade=1` adds CASCADE to CREATE/DROP. `version` empty = default; `schema` empty = default. Idempotency: agent first queries `pg_extension` for the named extension; if state already matches, returns `changed=0` without DDL. Connection fields mirror OpPostgresqlQuery. Envelope shape: {extension: string, state: \"present\"|\"absent\", changed: bool, prior_version: string|null, version: string|null}. Wire kind=14.",
      sequence: [
        { name: "kind", type: "uint8", const: 14 },
        { name: "name", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        { name: "state", type: "uint8" },
        { name: "version", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        { name: "ext_schema", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        { name: "cascade", type: "uint8" },
        { name: "db", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        { name: "login_user", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        { name: "login_password", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        { name: "login_unix_socket", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        { name: "login_host", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        { name: "login_port", type: "uint16" },
      ],
    },

    OpGetUrl: {
      description: "HTTP file download. Maps Ansible's `ansible.builtin.get_url` (subset). Downloads `url` to `dest`, optionally verifying a checksum and applying mode/owner/group. Idempotency: if `dest` already exists and `force=0`, the agent compares `checksum` (if given) against the existing file's hash; on match it returns `changed=0` without contacting the network. If `checksum` is empty and `dest` exists with `force=0`, the file is considered up-to-date and the download is skipped. With `force=1` the download always runs. Download is staged at `{dest}.rsansible.partial` next to `dest` (atomic rename on success; tmp removed on failure). `checksum` is `<algo>:<hex>` where algo ∈ {sha256, sha1, md5}; empty string disables verification. Post-download checksum mismatch surfaces as TaskError BAD_REQUEST and the tmp file is unlinked. `mode`/`owner`/`group` apply to the final dest path; mode=0 (i.e. no mode bits) means \"don't touch\"; owner/group empty mean \"don't touch\". `header_keys`/`header_values` are parallel arrays of request headers. `timeout_ms=0` means no timeout. `validate_certs=0` disables TLS verification (rustls dangerous_configuration). `follow_redirects` mirrors OpUri: 0=none, 1=safe (GET only, ≤10 hops), 2=all. mTLS bundle empty = no client cert. Envelope on stdout: {url, dest, checksum_src, checksum_dest, size, status_code, msg}. `checksum_src` is the operator-supplied target checksum (empty if none). `checksum_dest` is the actual sha256 of the final on-disk file (always computed, even when only a stat-skip happened, so the register has something to assert against). `changed=1` iff a new file was written (rename happened). `status_code` is 0 when no request was made (stat-skip path). Wire kind=15.",
      sequence: [
        { name: "kind", type: "uint8", const: 15 },
        { name: "url", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        { name: "dest", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        { name: "checksum", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        { name: "mode", type: "uint32" },
        { name: "owner", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        { name: "group", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        {
          name: "header_keys",
          type: "array",
          kind: "length_prefixed",
          length_type: "uint16",
          items: { type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        },
        {
          name: "header_values",
          type: "array",
          kind: "length_prefixed",
          length_type: "uint16",
          items: { type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        },
        { name: "timeout_ms", type: "uint32" },
        { name: "force", type: "uint8" },
        { name: "validate_certs", type: "uint8" },
        { name: "follow_redirects", type: "uint8" },
        { name: "client_cert_pem", type: "bytes", kind: "length_prefixed", length_type: "uint32" },
        { name: "client_key_pem", type: "bytes", kind: "length_prefixed", length_type: "uint32" },
        { name: "ca_bundle_pem", type: "bytes", kind: "length_prefixed", length_type: "uint32" },
      ],
    },

    OpAsyncStart: {
      description: "Fire-and-forget wrapper. Maps Ansible's `async: N, poll: 0` pattern. The agent spawns the inner op as a background task on the same process, records it in an in-memory job table keyed by the dispatch `seq`, and immediately returns TaskDone with envelope `{ansible_job_id: <seq>, started: 1, finished: 0, results_file: \"\"}`. The job's eventual stdout/stderr/exit_code is captured into the table entry and surfaced later via OpAsyncStatus. `timeout_ms=0` means no timeout; non-zero kills the inner task after the deadline and marks it as finished with a TIMEOUT error. The job table lives only for the agent process lifetime — controller-side polling must complete before the agent disconnects. Wire kind=16.",
      sequence: [
        { name: "kind", type: "uint8", const: 16 },
        { name: "timeout_ms", type: "uint32" },
        { name: "inner", type: "Op" },
      ],
    },

    OpAsyncStatus: {
      description: "Poll an async job started by OpAsyncStart. `job_id` is the original dispatch seq returned in the start envelope. Envelope on stdout: {ansible_job_id, started, finished, stdout, stderr, rc, results_file, msg, <inner envelope fields when finished and inner produced JSON>}. `finished=1` iff the inner task has terminated (success, error, or timeout). When `finished=1`, `rc` is the inner exit_code. When `finished=0`, only the ansible_job_id/started/finished fields are populated. Unknown job_id surfaces as TaskError NOT_FOUND. The agent does NOT delete completed jobs on first read — operators can poll repeatedly during a controller-side wait loop. Wire kind=17.",
      sequence: [
        { name: "kind", type: "uint8", const: 17 },
        { name: "job_id", type: "uint32" },
      ],
    },

    OpReadFile: {
      description: "Read the contents of a file on the agent host. Always streams the bytes back base64-encoded in a single stdout envelope shaped like Ansible's `slurp` module: `{content: \"<base64>\", source: \"<path>\", encoding: \"base64\"}`. `max_bytes` is a safety cap; 0 means no cap (the default in the controller is generous but finite — see ReadFileOp in ctl). If the file's length exceeds `max_bytes` the agent emits TaskError(BAD_REQUEST) without sending content. Missing path → TaskError(NOT_FOUND); permission denied → TaskError(PERMISSION_DENIED). Symlinks are followed (matches Ansible slurp). Wire kind=18.",
      sequence: [
        { name: "kind", type: "uint8", const: 18 },
        { name: "path", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        { name: "max_bytes", type: "uint32" },
      ],
    },

    OpUnarchive: {
      description: "Extract an archive that already lives on the agent host (matches `unarchive` with `remote_src: yes`; controller-pushed archives must come via OpWriteFile / OpGetUrl in a previous task). `src` is the path to the archive on the agent. `dest` is the target directory (must exist; v1 does NOT auto-create). `format` selects the codec: 0=auto (infer from `src` extension), 1=tar.gz, 2=tar.bz2, 3=tar.xz, 4=tar, 5=zip. Unknown extensions in auto mode → BAD_REQUEST. `creates` is an idempotency marker: when non-empty and the path exists, extraction is skipped and TaskDone(changed=0) is emitted without touching the archive. `keep_newer=1` skips extracting any entry whose mtime is older than the on-disk file at the same dest path (matches Ansible's `keep_newer`). `include` (zip only) restricts extraction to listed paths; empty = extract everything. `exclude` skips listed paths in any format; empty = exclude nothing. Both lists match against the *archive entry path* exactly (no globbing in v1). `has_mode=1` applies the low 12 bits of `mode` (chmod) to every extracted file/dir after extraction. Empty `owner`/`group` mean don't chown; non-empty values resolve via /etc/passwd /etc/group (no NSS) and chown every extracted path. `list_files=1` populates the envelope's `files` array with the list of extracted entry paths (relative to `dest`). Envelope on stdout: `{dest, src, extract_results: {}, handler, files: [...]}` matching Ansible's unarchive return shape; `handler` is one of `TgzArchive`/`TarArchive`/`TarBzipArchive`/`TarXzArchive`/`ZipArchive`. `changed=1` iff at least one file was actually written (i.e. a non-skipped entry was extracted). Hard failures (corrupt archive, partial extract, unsupported entry types like char/block devices) surface as TaskError. Symlinks inside the archive are honoured but rejected if they'd escape `dest` (zip-slip protection); same for absolute paths or `..` components in entry names. Wire kind=19.",
      sequence: [
        { name: "kind", type: "uint8", const: 19 },
        { name: "src", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        { name: "dest", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        { name: "format", type: "uint8" },
        { name: "creates", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        { name: "has_mode", type: "uint8" },
        { name: "mode", type: "uint32" },
        { name: "owner", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        { name: "group", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        { name: "keep_newer", type: "uint8" },
        { name: "list_files", type: "uint8" },
        {
          name: "include",
          type: "array",
          kind: "length_prefixed",
          length_type: "uint16",
          items: { type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        },
        {
          name: "exclude",
          type: "array",
          kind: "length_prefixed",
          length_type: "uint16",
          items: { type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        },
      ],
    },

    OpCopyTarget: {
      description: "Atomic file copy between two paths on the agent host. Maps Ansible's `copy:` module with `remote_src: yes` — the controller never reads the source bytes, the agent reads `src` and writes its contents to `dest` using the same tmp+fsync+rename ceremony as OpWriteFile. `has_mode=1` applies the low 12 bits of `mode` via chmod on the staged tmp before rename; `has_mode=0` skips chmod (the agent picks up whatever umask gives). Empty `owner`/`group` mean don't chown; non-empty values resolve via /etc/passwd /etc/group and chown the staged tmp before rename. `validate` follows OpWriteFile's contract: empty = no validation, non-empty = tokenize on whitespace + replace `%s` with the tmp path + run; non-zero exit aborts the rename and leaves dest untouched. Missing src → TaskError(NOT_FOUND). `changed=1` iff the on-disk bytes (or mode/owner/group) actually changed. Symlinks at `src` are followed (matches Ansible). Wire kind=28.",
      sequence: [
        { name: "kind", type: "uint8", const: 28 },
        { name: "src", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        { name: "dest", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        { name: "has_mode", type: "uint8" },
        { name: "mode", type: "uint32" },
        { name: "owner", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        { name: "group", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        { name: "validate", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
      ],
    },

    // Op dispatch. Each variant is identified by its leading `kind` byte; the
    // peek discriminator reads that byte without consuming it.
    Op: {
      description: "Discriminated union of all operations the agent can execute.",
      type: "discriminated_union",
      discriminator: { peek: "uint8" },
      variants: [
        { type: "OpExec", when: "value === 0" },
        { type: "OpShell", when: "value === 1" },
        { type: "OpWriteFile", when: "value === 2" },
        { type: "OpGatherFacts", when: "value === 3" },
        { type: "OpStat", when: "value === 4" },
        { type: "OpFile", when: "value === 5" },
        { type: "OpWaitFor", when: "value === 6" },
        { type: "OpLineInFile", when: "value === 7" },
        { type: "OpBlockInFile", when: "value === 8" },
        { type: "OpSystemd", when: "value === 9" },
        { type: "OpPackage", when: "value === 10" },
        { type: "OpUfw", when: "value === 11" },
        { type: "OpUri", when: "value === 12" },
        { type: "OpPostgresqlQuery", when: "value === 13" },
        { type: "OpPostgresqlExt", when: "value === 14" },
        { type: "OpGetUrl", when: "value === 15" },
        { type: "OpAsyncStart", when: "value === 16" },
        { type: "OpAsyncStatus", when: "value === 17" },
        { type: "OpReadFile", when: "value === 18" },
        { type: "OpUnarchive", when: "value === 19" },
        { type: "OpIptables", when: "value === 20" },
        { type: "OpRepository", when: "value === 21" },
        { type: "OpUser", when: "value === 22" },
        { type: "OpGroup", when: "value === 23" },
        { type: "OpAuthorizedKey", when: "value === 24" },
        { type: "OpGetent", when: "value === 25" },
        { type: "OpHostname", when: "value === 26" },
        { type: "OpTimezone", when: "value === 27" },
        { type: "OpCopyTarget", when: "value === 28" },
      ],
    },

    // ── Message variants ──────────────────────────────────────────────

    Hello: {
      description: "Sent agent → controller on startup. Carries identifying facts.",
      sequence: [
        { name: "kind", type: "uint8", const: 0 },
        // Arch / OS as small enum-ish bytes. Strings would work but the values
        // are bounded and the controller wants to match on them anyway.
        // 0=unknown, 1=x86_64, 2=aarch64, 3=arm, 4=riscv64, …
        { name: "arch", type: "uint8" },
        // 0=unknown, 1=linux, 2=darwin, 3=freebsd, …
        { name: "os", type: "uint8" },
        { name: "kernel", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        { name: "hostname", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
        { name: "uid", type: "uint32" },
        { name: "gid", type: "uint32" },
        { name: "agent_version", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
      ],
    },

    TaskDispatch: {
      description: "Sent controller → agent. Asks the agent to execute one Op.",
      sequence: [
        { name: "kind", type: "uint8", const: 1 },
        // Monotonic per-host sequence id chosen by the controller. The agent
        // echoes it back in TaskProgress/TaskDone/TaskError so the controller
        // can correlate streams.
        { name: "seq", type: "uint32" },
        // 0 = normal execution, 1 = dry-run / check mode. Each module decides
        // what check mode means for it (skip mutation, probe-only, etc.); the
        // controller composite ops (e.g. openssl_privatekey) also branch on it.
        { name: "check_mode", type: "uint8" },
        { name: "op", type: "Op" },
      ],
    },

    TaskProgress: {
      description: "Sent agent → controller during execution. One chunk of stdout or stderr.",
      sequence: [
        { name: "kind", type: "uint8", const: 2 },
        { name: "seq", type: "uint32" },
        // 0 = stdout, 1 = stderr. Modeled as a full byte (not a bit) so the
        // Rust generator's straightforward path handles it.
        { name: "stream", type: "uint8" },
        { name: "chunk", type: "bytes", kind: "length_prefixed", length_type: "uint32" },
      ],
    },

    TaskDone: {
      description: "Sent agent → controller. Terminal — no further messages for this seq. `started_unix_ns` and `finished_unix_ns` are the agent's host-wall-clock timestamps (nanoseconds since the UNIX epoch) bracketing the module's work, captured before the first side-effect and after the last. Always on the wire — surfaced behind the `rsansible::timing` tracing target. Note: the host's clock can be skewed from the controller's; (finished − started) is skew-immune work time; absolute values are only meaningful when compared to the controller's own dispatch/receive instants with skew in mind.",
      sequence: [
        { name: "kind", type: "uint8", const: 3 },
        { name: "seq", type: "uint32" },
        { name: "exit_code", type: "int32" },
        // 0 = unchanged, 1 = changed. Idempotency reporting (Ansible-style).
        { name: "changed", type: "uint8" },
        // 0 = ran, 1 = skipped (e.g. shell/exec under check_mode, or method-aware uri skip).
        // Distinguished from `changed=0` so end-of-run summaries can say
        // "ok=N changed=M skipped=K" instead of conflating no-ops with skips.
        { name: "skipped", type: "uint8" },
        { name: "started_unix_ns", type: "uint64" },
        { name: "finished_unix_ns", type: "uint64" },
      ],
    },

    TaskError: {
      description: "Sent agent → controller. Module-level failure before/instead of TaskDone.",
      sequence: [
        { name: "kind", type: "uint8", const: 4 },
        { name: "seq", type: "uint32" },
        // Coarse error category for programmatic handling. Free-form detail in `message`.
        // 0=internal, 1=bad_request, 2=io, 3=permission, 4=timeout, 5=not_found, 6=spawn_failed
        { name: "code", type: "uint8" },
        { name: "message", type: "string", kind: "length_prefixed", length_type: "uint16", encoding: "utf8" },
      ],
    },

    Bye: {
      description: "Sent controller → agent. Agent flushes and exits cleanly.",
      sequence: [
        { name: "kind", type: "uint8", const: 5 },
      ],
    },

    Ping: {
      description: "Sent controller → agent immediately after Hello. The agent responds with `Pong` carrying its wall-clock receive and send timestamps so the controller can estimate the clock offset between the two hosts (NTP-style). The Ping itself carries no timestamp; the controller remembers its own send time and captures its own receive time on Pong, so all four timestamps (T1=ctl-send, T2=agent-recv, T3=agent-send, T4=ctl-recv) feed into `offset = ((T2-T1) + (T3-T4)) / 2`.",
      sequence: [
        { name: "kind", type: "uint8", const: 6 },
      ],
    },

    Pong: {
      description: "Sent agent → controller in response to `Ping`. `agent_recv_unix_ns` is captured as close to the Ping frame's read as practical; `agent_sent_unix_ns` is captured just before the Pong is queued for writing. Together with the controller's own T1/T4 these let the controller compute the host's clock offset for the duration of this connection.",
      sequence: [
        { name: "kind", type: "uint8", const: 7 },
        { name: "agent_recv_unix_ns", type: "uint64" },
        { name: "agent_sent_unix_ns", type: "uint64" },
      ],
    },

    // Top-level union for the whole protocol.
    Message: {
      description: "Discriminated union of every wire message in either direction.",
      type: "discriminated_union",
      discriminator: { peek: "uint8" },
      variants: [
        { type: "Hello", when: "value === 0" },
        { type: "TaskDispatch", when: "value === 1" },
        { type: "TaskProgress", when: "value === 2" },
        { type: "TaskDone", when: "value === 3" },
        { type: "TaskError", when: "value === 4" },
        { type: "Bye", when: "value === 5" },
        { type: "Ping", when: "value === 6" },
        { type: "Pong", when: "value === 7" },
      ],
    },
  },
}
